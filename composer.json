{
    "name": "clairvoyance/chat-ai-lib",
    "description": "Library for conversing with an AI character powered by LLM for PHP",
    "type": "library",
    "require": {
        "openai-php/client": "^0.8.5",
        "symfony/http-client": "^7.0",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.1",
        "monolog/monolog": "^3.6",
        "psy/psysh": "^0.12.3"
    },
    "autoload": {
        "psr-4": {
            "Clair\\Ai\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Ui-Okuyama"
        }
    ],
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
