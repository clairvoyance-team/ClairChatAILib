{
    "name": "clairvoyance/chat-ai-lib",
    "description": "Library for conversing with an AI character powered by LLM for PHP",
    "type": "library",
    "require": {
        "php": "^8.2",
        "openai-php/client": "^0.19.1",
        "symfony/http-client": "^7.0",
        "nyholm/psr7": "^1.8",
        "php-http/discovery": "^1.20"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.1",
        "monolog/monolog": "^3.6",
        "psy/psysh": "^0.12.3"
    },
    "autoload": {
        "psr-4": {
            "Clair\\Ai\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Clair\\Ai\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Ui-Okuyama"
        }
    ],
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}